# SigmaAssistant environment configuration
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit your real API keys.

# ============================================================
# LLM provider selection
# ============================================================
# Which backend handles the primary (rule-generation) calls.
# Supported: gemini
LLM_PROVIDER=gemini

# Which backend handles the cheap/economy calls (classification,
# validation, translation). Leave empty to route everything through
# Gemini, or set to `ollama` to use a local Ollama server for the
# lighter stages.
# Supported: <empty> | ollama
ECONOMY_PROVIDER=

# ============================================================
# Gemini (Google AI Studio)
# ============================================================
GEMINI_API_KEY=your-google-ai-studio-key-here

# Models per tier — change only if you know what you're doing.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FAST_MODEL=gemini-2.5-flash-lite
GEMINI_ECONOMY_MODEL=gemini-2.0-flash

# Rate limits (requests per minute). Defaults match Google AI Studio
# free-tier quotas; bump these if you have a paid key.
GEMINI_PRIMARY_RPM=9
GEMINI_FAST_RPM=14
GEMINI_ECONOMY_RPM=29

# ============================================================
# Ollama (only used if ECONOMY_PROVIDER=ollama)
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b

# ============================================================
# Optional: remote Ollama via SSH tunnel
# ============================================================
# Set these if your Ollama server is on a remote host reachable
# only via SSH. The app will auto-open a port-forward on startup.
SPARK_SSH_HOST=
SPARK_SSH_USER=
# SPARK_SSH_KEY=~/.ssh/id_ed25519

# ============================================================
# Embeddings (ChromaDB vector store)
# ============================================================
# `local` uses sentence-transformers/all-MiniLM-L6-v2 (free, offline).
# Other values currently unused.
EMBEDDING_PROVIDER=local
